# NFCom API Configuration
#
# Certificate (PFX/P12 file) for mTLS with SEFAZ
NFCOM_CERT_PATH=/app/cert.p12
NFCOM_CERT_PASSWORD=your-certificate-password-here

# SEFAZ endpoint (default: SEFAZ Virtual RS Homologação)
NFCOM_SEFAZ_URL=https://dfe-portal.svrs.rs.gov.br/NFCom

# Optional: custom truststore path
# NFCOM_TRUSTSTORE_PATH=/app/cacerts
